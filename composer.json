{
    "name": "super-kernel/context",
    "type": "library",
    "description": "The context component for super-kernel.",
    "license": "MIT",
    "keywords": [
        "php",
        "super-kernel",
        "context"
    ],
    "homepage": "https://github.com/super-kernel/context",
    "support": {
        "issues": "https://github.com/super-kernel/context/issues",
        "source": "https://github.com/super-kernel/context"
    },
    "autoload": {
        "psr-4": {
            "SuperKernel\\Context\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "classmap-authoritative": true,
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "require": {
        "php": "~8.4.0",
        "super-kernel/contract": "~1.0.0"
    },
    "require-dev": {
        "swoole/ide-helper": "~6.0.0"
    }
}
